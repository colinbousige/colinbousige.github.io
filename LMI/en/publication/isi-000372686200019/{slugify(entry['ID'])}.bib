@article{ISI:000372686200019,
 abstract = {Vapor pressures of pure and aqueous diethylenetriamine (DETA) and
dipropylenetriamine (DPTA) were measured by means of a static apparatus
at temperatures between (283 and 363) K. The data were correlated with
the Antoine equation and fitted to Redlich-Kister equation using
Barker's method. Additionally, the NRTL, UNIQUAC models were used to
correlate total pressures. (C) 2016 Elsevier B.V. All rights reserved.},
