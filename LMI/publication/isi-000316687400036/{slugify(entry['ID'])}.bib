@article{ISI:000316687400036,
 abstract = {The hydrates of cobalt and nickel nitrates are highly relevant as
precursors for the preparation of mixed ceramics. In order to verify the
numerous bibliographical data, systematic solubility measurements in
aqueous medium under atmospheric pressure and a critical evaluation have
been undertaken. By taking solvation phenomena into account, it has
proved possible to correlate all the phenomena observed, to obtain
equations representative of the liquidus curves, and to refine and
extrapolate the experimental curves. The whole stable and metastable
coordinates of the invariant transformations in both binary systems have
been calculated or more accurately determined.},
