@article{ISI:000344977600051,
 abstract = {New solubility data for binary (ethylene glycol (or MEG) + cyclohexane
or para-xylene), ternary (MEG/water + cyclohexane or para-xylene), and
quaternary systems (MEG/water + trans- and cis-1,2-dimethylcyclohexane
or trans- and cis-decahydronaphthalene (decalin)) under atmospheric
pressure at three temperatures between 280.15 K and 333.15 K are
reported. No literature data was available to compare with the present
study. The consistency of the experimental data was checked through an
OthmerTobias plot. The nonrandom two-liquid (NRTL) and the
SoaveRedlichKwong modified (SRKM) thermodynamic models were used to
correlate the experimental liquidliquid equilibrium (LLE) data for all
of the studied systems.},
