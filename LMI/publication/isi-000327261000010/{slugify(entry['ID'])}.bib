@article{ISI:000327261000010,
 abstract = {A microcontact printing method using a flat metal-embedded
polydimethylsiloxane (PDMS) stamp has been demonstrated. Metal patterns
embedded in the PDMS stamp act as a molecular transport barrier. The
flat stamp avoids the mechanical deformation of the stamp tip which is a
crucial problem when printing the stamp onto a substrate.},
