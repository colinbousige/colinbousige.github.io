@inproceedings{ISI:000279657600016,
 abstract = {Despite outstanding properties, the development of 3C-SiC electronics is
still suffering from the lack of bulk 3C-SiC substrates. Up to now,
there is no real seed and optimized growth processes for this material.
We address in this work the bulk growth of 3C-SiC by a two-step-liquid
phase approach. By coupling experiments with global process simulation,
we address the problems that must be overcome to consider the solution
growth technique as a possible approach for the growth of bulk 3C-SiC.},
