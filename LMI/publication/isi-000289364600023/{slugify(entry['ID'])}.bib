@article{ISI:000289364600023,
 abstract = {The solid state structures of four complexes between
para-sulphonato-calix[4] arene and phenanthroline have been
determined. Three are simple complexes between the two molecules however
the fourth contains aluminium cations, from a solid state extraction
involving aluminium foil used in the weighing step. The phenanthroline
cations are involved both in inclusion and also in various assemblies
formed by aromatic-aromatic stacking.},
