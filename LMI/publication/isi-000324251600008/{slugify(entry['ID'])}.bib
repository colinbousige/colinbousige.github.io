@article{ISI:000324251600008,
 abstract = {We report herein, the synthesis, and spectral and electrochemical
characterization of a series of phthalocyaninato zinc complexes where
two biomedically potential structures; crown ether and phthalocyanine
moities were gathered on the same molecule. The effect of number of
crown ether moieties on metal ion binding properties, as well as proton
sensitivity were investigated by using electronic absorption and
fluorescence emission spectra. Spectral behaviors of the zinc
phthalocyanine complexes fused with one crown ether;
Zn[Pc(15C5)(C6H13)(6)] and four crown ether; Zn[Pc(15C5)(4)] in
presence of Na+ and K+ ions were investigated into detail because of
host-guest interactions of subjective ions with crown ether moieties,
and compared with the crown ether free phthalocyanine;
Zn[Pc(C6H13)(8)].},
