@article{ISI:000275577100004,
 abstract = {Novel boron nitride (BN) fibers have been developed with diameters
ranging from the nano-to microscale by thermal conversion of
as-electrospun fibers from polyacrylonitrile and
poly[B-(methylamino)borazine] blend solutions. Such a new class of
ceramic fibers is seen as potential candidate for thermal management
applications and filtration systems in harsh environments.},
