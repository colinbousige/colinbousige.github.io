@article{ISI:000299048500023,
 abstract = {The composition, the structure and the optical properties of
mesostructured hybrid silica films elaborated by sol-gel routine are
studied versus the temperature of the post treatment by comparing
ellipsometric measurements, atomic force microscopy and electronic
microscopy characterizations, X-ray diffraction and thermal analysis.
This paper shows that the refractive index variation is a combination
between the structure contraction, the solvent evaporation, the silica
wall condensation and the pyrolysis of the copolymer. We also
investigate the optical properties of thermally grown silver
nanoparticles in the mesotructured films and we demonstrate that these
properties depend on the optical properties of the host matrix and on
the silver concentration profile in the film. (C) 2011 Optical Society
of America},
