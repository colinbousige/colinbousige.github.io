@article{ISI:000379431000020,
 abstract = {The first structure elucidation of a lamellar gold thiolate coordination
polymer is described. [Au(p-SPhCO2Me)](n) is obtained from the
simultaneous esterification of mercaptobenzoic acid and reduction of the
Au(III) precursor. Despite the presence of aurophilic interactions, the
intense phosphorescence (QY similar to 70%) originates from
intra-ligand and metal-to-ligand transitions.},
