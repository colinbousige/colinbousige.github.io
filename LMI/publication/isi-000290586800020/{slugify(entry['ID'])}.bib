@article{ISI:000290586800020,
 abstract = {Two cubic, single crystal silicon carbide (3C-SiC) films with similar
thickness are shown to exhibit significantly different optical
properties at mid-infrared wavelengths. Depth profiling by
time-of-flight secondary ion mass spectroscopy indicates that these two
films have substantially different n-type impurity concentrations that
are responsible for the observed differences in optical absorption. The
influence of impurities manifests as substantially different planar
defect morphologies. (C) 2011 American Institute of Physics.
[doi:10.1063/1.3585098]},
