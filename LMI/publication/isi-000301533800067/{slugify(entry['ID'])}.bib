@inproceedings{ISI:000301533800067,
 abstract = {This work reports on Differential Scanning Calorimetry (DSC)
measurements performed on Ti-Al metallic layers stacks deposited on
n(+)-GaN. The aim is to get better understanding of the mechanisms
leading to ohmic contact formation during the annealing stage. Two
exothermic peaks were found, one below 500 degrees C and the other one
around 660 degrees C. They can be respectively attributed to Al3Ti and
Al2Ti compounds formation. The locations of these peaks provide clear
evidence of solid-solid reactions. Lowest contact resistance is well
correlated with the presence of Al3Ti compound, corresponding to
Al(200nm)/Ti(50nm) stoichiometric ratio. Subsequently, Al(200 nm) Ti(50
nm) stacks on n(+)-GaN were annealed from 400 degrees C to 650 degrees
C. Specific Contact Resistivity (SCR) values stay in the mid 10(-5)
Omega.cm(2) range for annealing temperatures between 450 degrees C and
650 degrees C. Such low-temperature annealed contacts on n+-GaN may open
new device processing routes, simpler and cheaper, in which Ohmic and
Schottky contacts are annealed together. (C) 2010 WILEY-VCH Verlag GmbH
& Co. KGaA, Weinheim},
