@article{ISI:000302663500017,
 abstract = {A clean and partially green route to monoalkyled thiacalix[4]arenes
has been demonstrated. We have discovered that tetraalkylammonium halide
can cleave selectively one of the two aryl alkyl ethers of dialkylated
para-tert-butylthiacalix[4]arenes. Thus, p-tert-butyl
thiacalix[4]arenes differently monoalkyled at the lower rim with
acetyl, propyl, and benzyl group were synthesized in good yield. (C)
