@article{ISI:000297016100010,
 abstract = {Four transition-metal coordination compounds with D-and L-mandelic acid
(Hmand) were synthesized and structurally and magnetically
characterized. The structure, refined as
\M-II(L/D-mand)(4-MePy)(3)\(n)center dot n(ClO4) (M = Co-II and Ni-II;
4-MePy = 4-methylpyridine), reveals a chiral 1D polymer that consists of
a chain complex built by the monocarboxylate ligand. The coordination
sphere of the paramagnetic center is chiral and completed by three
4Me-Py ligands. Magnetic studies reveal the presence of a ferromagnetic
interaction between the Ni-II centers [J = 0.64(5)-0.54(7) cm(-1) and
zero-field splitting (ZFS) = -1.38(1)/-1.05(2) cm(-1)]. In the case of
the Co-II-based polymer, ferromagnetic but negligible interaction is
suspected.},
