Journal = {{JOURNAL OF NANOSCIENCE AND NANOTECHNOLOGY}},
Year = {{2015}},
Volume = {{15}},
Number = {{9}},
Pages = {{6308-6326}},
Month = {{SEP}},
Abstract = {{During the 10 last years, there has been a growing interest in
   calix{[}n]arene capped silver nanoparticles for their uses in biosensing
   and much more recently for their intrinsic therapeutic properties. Cost
   effective, portable and ultra-sensitive analytical tools are one of the
   major expectations of silver nanoparticles capped with calix{[}n]arenes.
   Their uses for detecting a wide range of hazardous molecules and
   biological compounds by different physical approaches (optical or
   electrical) are reviewed in depth here. A second part deals with their
   biological activities. These hybrid nanoparticles have been shown to
   possess antibacterial properties, and to reach antiviral and anti-cancer
   targets.}},
