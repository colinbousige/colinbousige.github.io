@article{ ISI:000294242700055,
Author = {Sadhukhan, Dipali and Ray, Aurkie and Pilet, Guillaume and Rizzoli,
   Corrado and Rosair, Georgina M. and Gomez-Garcia, Carlos J. and
   Signorella, Sandra and Bellu, Sebastian and Mitra, Samiran},
Title = {{Weak Interactions Modulating the Dimensionality in Supramolecular
   Architectures in Three New Nickel(II)-Hydrazone Complexes,
   Magnetostructural Correlation, and Catalytic Potential for Epoxidation
   of Alkenes under Phase Transfer Conditions}},
Journal = {{INORGANIC CHEMISTRY}},
Year = {{2011}},
Volume = {{50}},
Number = {{17}},
Pages = {{8326-8339}},
Month = {{SEP 5}},
Abstract = {{Three different ONO donor acetyl hydrazone Schiff bases have been
   synthesized from the condensation of acetic hydrazide with three
   different carbonyl compounds: salicylaldehyde (HL1),
   2-hydroxyacetophenone (HL2), and 2, 3-dihydroxybenzaldehyde (HL3). These
   tridentate ligands are reacted with Ni(OOCCF3)(2)center dot xH(2)O to
   yield three new Ni(II) complexes having distorted octahedral geometry at
   each Ni center: {[}Ni(L-1)(OOCCF3)(CH3OH)](2) (1),
   {[}Ni(L-2)(OOCCF3)(H2O)](2) (2), and
   {[}Ni(L-3)((LH)-H-3)](OOCCF3)(H2O)(1.65)(CH3OH)(0.35) (3). The ligands
   and the complexes have been characterized by elemental analysis and IR
   and UV-vis spectroscopy, and the structures of the complexes have been
   established by single crystal X-ray diffraction (XRD) study. 1 and 2 are
   centrosymmetric dinuclear complexes and are structural isomers whereas 3
   is a his chelated cationic monomer coordinated by one neutral and one
   monoanionic ligand. O-H center dot center dot center dot O hydrogen
   bonds in 3 lead to the formation of a dimer. Slight steric and
   electronic modifications in the ligand backbone provoke differences in
   the supramolecular architectures of the complexes, leading to a variety
   of one, two, and three-dimensional hydrogen bonded networks in complexes
   1-3 respectively. Variable temperature magnetic susceptibility
   measurements reveal that moderate antiferromagnetic interactions operate
   between phenoxo bridged Ni(II) dimers in 1 and 2 whereas very weak
   antiferromagnetic exchange occurs through hydrogen bonding and pi-pi
   stacking interactions in 3. All complexes are proved to be efficient
   catalysts for the epoxidation of alkenes by NaOCl under phase transfer
   condition, The efficiency of alkene epoiddation is dramatically enhanced
   by lowering the pH, and the reactions are supposed to involve high
   valent Ni-III-OCl or Ni-III-O center dot intermediates. 3 is the best
   epoxidation catalyst among the three complexes with 99\% conversion and
   very high turnover number (TON, 396).}},
Publisher = {{AMER CHEMICAL SOC}},
Address = {{1155 16TH ST, NW, WASHINGTON, DC 20036 USA}},
Type = {{Article}},
Language = {{English}},
Affiliation = {{Mitra, S (Reprint Author), Jadavpur Univ, Dept Chem, Raja SC Mullick Rd, Kolkata 700032, W Bengal, India.
   Sadhukhan, Dipali; Ray, Aurkie; Mitra, Samiran, Jadavpur Univ, Dept Chem, Kolkata 700032, W Bengal, India.
