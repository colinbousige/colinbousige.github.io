Month = {{SEP}},
Abstract = {{In the title complex, {[}Ni(C5H9NO2)(2)(H2O)(2)], the Ni-II atom,
   located on a centre of inversion, is trans-coordinated by two O atoms
   and two N atoms from D-bidentate valine and L-bidentate valine ligands
   and two water O atoms in an octahedral geometry. In the crystal, the
   discrete mononuclear units are linked into a three-dimensional network
   via O-H center dot center dot center dot O and N-H center dot center dot
   center dot O hydrogen bonds. C-H center dot center dot center dot O
   inter-actions are also observed.}},
