@article{ ISI:000432502800027,
Author = {Kamath, Amarjit and Brahman, Dhiraj and Pilet, Guillaume and Sinha,
   Biswajit and Tamang, Abiral},
Title = {{{[}Bis(picolinate-kappa N-2:O)Copper(II)] di(benzene1,3,5-tricarboxylic
   acid): Hydrothermal synthesis, structural characterization, magnetic
   properties and DFT study}},
Journal = {{JOURNAL OF MOLECULAR STRUCTURE}},
Year = {{2018}},
Volume = {{1165}},
Pages = {{228-235}},
Month = {{AUG 5}},
Abstract = {{A new metal-organic hybrid complex {[}Bis(picolinate-kappa
   N-2:O)Copper(II)] di(benzene-1,3,5- tricarboxylic acid) was synthesized
   hydrothermally. Physico-chemical characterization of the complex was
   perfomed with FFIR spectroscopy, single crystal X-ray diffraction, TGA,
   EPR, SQUID and FESEM. Single crystal X-ray diffraction study revealed
   that the complex crystallizes in a monoclinic form with space group P1
   21/c 1. The unit cell dimensions are a = 4.9853 (4), b = 13.1082 (5), c
   = 21.6616 (8) angstrom; the axial angles are alpha = 90 degrees, beta=
   91.230 degrees (6) and gamma = 90 degrees. The asymmetric unit of the
   title complex is composed of a Cu(II) ion and two 2-picolinic acid
   anions. The Cu(II) ion occupies the centre of symmetry coordinated
   through two pyridine nitrogen atoms and two oxygen atoms of the carboxyl
   group giving rise to a slightly distorted square planar coordination
   environment. EPR and SQUID studies revealed it to be a stable
   paramagnetic material. The stability of the complex was well justified
   by thermogravimetric and DFT studies. (C) 2018 Elsevier B.V. All rights
   reserved.}},
