@article{ ISI:000286707400008,
Author = {Chassagneux, F. and Chiriac, R. and Bessueille, F. and Karabulut, M. and
   Bois, L. and Parola, S.},
Title = {{Ellipsoporosimetry and thermoporometry analyses of mesoporous titania
   film containing silver nanoparticles}},
Journal = {{MICROPOROUS AND MESOPOROUS MATERIALS}},
Year = {{2011}},
Volume = {{139}},
Number = {{1-3}},
Pages = {{52-58}},
Month = {{MAR}},
Abstract = {{An investigation of the porosity of a thin mesoporous titania film was
   performed using both ellipsoporosimetry and thermoporometry. These films
   are prepared using the sol-gel process with a block copolymer
   PEO-PPO-PEO (P123) and a thermal treatment at 350 degrees C. The film is
   constituted by a single layer with oblate pores whose small and high
   diameters are respectively equal to 5 and 7 nm. The porous volume is
   31\% or 36\% depending of the method used. The porous titania film has
   also been used as a template for the growth of silver nanoparticles.
   Impregnation of the porous film in a silver salt solution is followed by
   a reduction step with sodium borohydride. Ellipsoporosimetry is then the
   only way to study the porosity, using a two-layer model. The first thin
   layer (35 nm) is slightly porous and contains a lot of large silver
   nanoparticles. The second under layer is thicker (180 nm) and has a
   porosity similar to the empty layer one. (c) 2010 Elsevier Inc. All
   rights reserved.}},
