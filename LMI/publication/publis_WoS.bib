@article{ ISI:000280235800055,
Author = {Chamoun, R. and Demirci, U. B. and Cornu, D. and Zaatar, Y. and Khoury,
   A. and Khoury, R. and Miele, P.},
Title = {{Cobalt-supported alumina as catalytic film prepared by electrophoretic
   deposition for hydrogen release applications}},
Journal = {{APPLIED SURFACE SCIENCE}},
Year = {{2010}},
Volume = {{256}},
Number = {{24}},
Pages = {{7684-7691}},
Month = {{OCT 1}},
Abstract = {{Shaped catalysts are crucial for technological applications. In this
   context, we have developed Co-alpha Al(2)O(3) catalyst films deposited
   over Cu plates to be used in hydrogen generation by hydrolysis of sodium
   borohydride NaBH(4) in alkaline solution. The Co-alpha Al(2)O(3) films
   were prepared by electrophoretic deposition according to six different
   routes. While five of them failed in fabricating adhering films, the
   sixth route, consisting of electrodepositing Co-impregnated alpha
   Al(2)O(3), showed promising results. The as-obtained shaped catalysts
   were stable when hydrogen vigorously bubbled and catalyzed the NaBH(4)
   hydrolysis with attractive hydrogen generation rates. These results open
   an alternative route for preparing shaped catalysts in this reaction.
   (C) 2010 Elsevier B.V. All rights reserved.}},
