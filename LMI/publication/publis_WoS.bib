Title = {{Crystal structure of human tooth enamel studied by neutron diffraction}},
Journal = {{MATERIALS RESEARCH EXPRESS}},
Year = {{2015}},
Volume = {{2}},
Number = {{2}},
Month = {{FEB}},
Abstract = {{Crystal structure of human tooth enamel was investigated using
   high-resolution neutron powder diffraction. Excellent agreement between
   observed and refined patterns is obtained, using the hexagonal
   hydroxyapatite model for the tooth enamel, where a large hydroxyl
   deficiency similar to 70\% is found in the 4e site. Rietveld refinements
   method combined with the difference Fourier maps have revealed, however,
   that the hydroxyl ions are not only disordered along the c-axis but also
   within the basal plane. Additional H ions located at the 6h site and
   forming HPO42- anions were found.}},
