@article{ ISI:000327530300019,
Author = {Vo-Ha, A. and Carole, D. and Lazar, M. and Tournier, D. and Cauwet, F.
   and Souliere, V. and Thierry-Jebali, N. and Brosselard, P. and Planson,
   D. and Brylinski, C. and Ferro, G.},
Title = {{Understanding the growth of p-doped 4H-SiC layers using
   vapour-liquid-solid transport}},
Journal = {{THIN SOLID FILMS}},
Year = {{2013}},
Volume = {{548}},
Pages = {{125-129}},
Month = {{DEC 2}},
Abstract = {{The present study reports the fabrication of localized p-doped silicon
   carbide zones on 4H-SiC substrate. Selective epitaxial growth of p-doped
   SiC was performed using the vapour-liquid-solid transport in Al-Si
   liquid phase. Focus was made on the understanding of the mechanism
   involved during such growth. It was shown that despite the need of
   starting the growth during the heating ramp, the deposition proceeds in
   a 2D manner at low temperature. Rather high growth rates were obtained
   (56.7-380 nm/min) which are related to the thinness of the liquid phase
   (<3 mu m). Argon carrier gas leads to an increase of growth rate
   compared to H-2 due to the reducing effect of this latter gas. The
   results revealed that the surface morphology was more affected by the
   initial Si content of the liquid than by the growth rate. It is proposed
   that the Si content of the liquid is a very influent parameter because
   of its importance in the competition between SiC or Al4C3 stabilization.
   (C) 2013 Elsevier B.V. All rights reserved.}},
