@inproceedings{ ISI:000309431000034,
Author = {Jegenyes, N. and Souliere, V. and Cauwet, F. and Ferro, G.},
Editor = {{Devaty, RP and Dudley, M and Chow, TP and Neudeck, PG}},
Title = {{Surface morphology evolution after epitaxial growth on 4 degrees
   off-axis 4H-SiC substrate}},
Booktitle = {{SILICON CARBIDE AND RELATED MATERIALS 2011, PTS 1 AND 2}},
Series = {{Materials Science Forum}},
Year = {{2012}},
Volume = {{717-720}},
Pages = {{145-148}},
Note = {{14th International Conference on Silicon Carbide and Related Materials
   (ICSCRM 2011), Cleveland, OH, SEP 11-16, 2011}},
Organization = {{Cree; Keithley Instruments; AIXTRON; Dow Corn Elect Solut; Gen Elect;
   CuttingEdgeIons com; Off Naval Res; NASA Glenn Res Ctr; Infineon;
   SemiSouth; Microsemi; OAI}},
Abstract = {{Chemical vapour deposition in a cold wall reactor working at atmospheric
   pressure was used to study the homoeptaxial growth of 4H-SiC on 4
   degrees off misoriented substrates from silane and propane precursors.
   The effect of various growth parameters (temperature 1450-1650 degrees
   C, C/Si ratio 1-7 and thickness 2.5-10 mu m) were studied in order to
   determine the best conditions for obtaining smooth surfaces after
   epitaxy. It is shown that the main source of roughness is surface
   undulation which easily appears during growth, especially at low C/Si
   ratios or high temperature (up to 1600 degrees C). Temperatures above
   1600 degrees C and C/Si ratio of 1 give the best results. When reducing
   temperature, defects formation is competing with surface undulation.}},
