@inproceedings{ ISI:000335321100070,
Author = {Thierry-Jebali, Nicolas and Chiriac, Rodica and Brylinski, Christian},
Book-Group-Author = {{IEEE}},
Title = {{Characterization and Kinetic Monitoring of the Reactions between TixAly
   Phases in Ti-Al based Ohmic Contacts on n-type GaN by Differential
   Scanning Calorimetry (DSC)}},
Booktitle = {{2013 19TH INTERNATIONAL WORKSHOP ON THERMAL INVESTIGATIONS OF ICS AND
   SYSTEMS (THERMINIC)}},
Year = {{2013}},
Pages = {{372-375}},
Note = {{19th International Workshop on Thermal Investigations of ICs and Systems
   (THERMINIC), Berlin, GERMANY, SEP 25-27, 2013}},
Organization = {{Fraunhofer Forum Berlin}},
Abstract = {{This work reports on DSC measurements performed on Ti-Al metallic layers
   stacks deposited on n+-GaN. The aim is to get better understanding of
   the mechanisms leading to ohmic contact formation during the annealing
   stage. Two exothermic DSC peaks were found : one below 500 degrees C and
   the other one around 660 C. They can be respectively attributed to Al3Ti
   and Al2Ti compounds formation. Lowest contact resistance is well
   correlated with the presence of Al3Ti compound, corresponding to
   Al(200nm) / Ti(50nm) stoichiometric ratio. Subsequently, Al (200 nm) /
   Ti(50 nm) stacks on n+-GaN were comparatively annealed from 400 degrees
   C to 650 degrees C. Specific Contact Resistivity (SCR) values stay in
   the mid 10-5 Omega.cm(2) range for annealing temperatures between 450
   degrees C and 650 degrees C. Such low-temperature annealed contacts on
   n+-GaN may open new device processing routes, simpler and cheaper, in
   which Ohmic and Schottky contacts are annealed together.}},
