   Khaled and Nsouli, Bilal},
Editor = {{Soueidan, M and Roumie, M and Masri, P}},
Title = {{On the Characterization of Ultra Thin Al Films Deposited onto SiC
   Substrate Using PIXE Technique}},
Booktitle = {{ADVANCES IN INNOVATIVE MATERIALS AND APPLICATIONS}},
Series = {{Advanced Materials Research}},
Year = {{2011}},
