@article{ ISI:000280514800012,
Author = {De Montigny, Frederic and Bast, Radovan and Gomes, Andre Severo Pereira
   and Pilet, Guillaume and Vanthuyne, Nicolas and Roussel, Christian and
   Guy, Laure and Schwerdtfeger, Peter and Saue, Trond and Crassous, Jeanne},
