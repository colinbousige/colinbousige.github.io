   Cavaliere, S., Univ Montpellier 2, CNRS, Inst Charles Gerhardt, Lab Agregats Interfaces \& Mat Energie,UMR 5253, F-34095 Montpellier 5, France.}},
DOI = {{10.1016/j.cattod.2011.02.016}},
ISSN = {{0920-5861}},
