@article{ ISI:000344791900005,
Author = {Yuan, Sheng and Toury, Berangere and Benayoun, Stephane and Chiriac,
   Rodica and Gombault, Francois and Journet, Catherine and Brioude, Arnaud},
Title = {{Low-Temperature Synthesis of Highly Crystallized Hexagonal Boron Nitride
   Sheets with Li3N as Additive Agent}},
Journal = {{EUROPEAN JOURNAL OF INORGANIC CHEMISTRY}},
Year = {{2014}},
Number = {{32}},
Pages = {{5507-5513}},
Month = {{NOV}},
Abstract = {{Highly crystallized hexagonal boron nitride (h-BN) sheets were obtained
   by a versatile method modifying the original synthesis by using an
   additive agent and, as a consequence, decreasing the temperature for the
   ceramization step (1200-1400 degrees C). This synthesis is based on the
   polymer-derived ceramics (PDCs) route using liquid-state polyborazylene
   (PBN) mixed with lithium nitride (Li3N) micropowders as additive agent.
   We have demonstrated that incorporation of Li3N as a crystallization
   promoter allows the onset of crystallization of h-BN at lower
   temperatures. Consequently, a high crystallization rate can be obtained
   from 1000 degrees C for bulk boron nitride, whereas the temperature has
   to be 1600-1800 degrees C under classical conditions. A series of
   samples incorporating Li3N (5 wt.-\%) and annealed at various
   temperatures from 600 to 1400 degrees C was prepared and structurally
   characterized by Raman spectroscopy, XRD analyis, and TEM.
   Well-crystallized sheets with thicknesses of nanometers can be easily
   obtained by applying this method.}},
