   Camassel, J. and Polychroniadis, E. K. and Yakimova, R.},
Title = {{Effect of initial substrate conditions on growth of cubic silicon
   carbide}},
Journal = {{JOURNAL OF CRYSTAL GROWTH}},
Year = {{2011}},
Volume = {{324}},
Number = {{1}},
Pages = {{7-14}},
Month = {{JUN 1}},
Abstract = {{In order to analyze the epitaxial growth of cubic silicon carbide by
   sublimation epitaxy on different substrates, four different 6H-SiC
   substrate preparations were used: (i) as-received, (ii) re-polished,
   (iii) annealed and covered by silicon layer and (iv) with (1 1 1) 3C-SiC
   buffer layer. Almost 100\% coverage and low twin density was achieved
   when grown on the buffer layer. The XRD and TEM characterizations show
   better material quality when the layer is grown directly on 6H-SiC
   substrates. Background doping evaluated by LTPL is in the range of
   10(16) cm(-3) for N and 10(16) cm(-3) for Al in all grown layers. (C)
   2011 Elsevier B.V. All rights reserved.}},
