@article{ ISI:000322863300055,
Author = {Iasco, Olga and Novitchi, Ghenadie and Jeanneau, Erwann and Luneau,
   Dominique},
Title = {{Lanthanide Triangles Sandwiched by Tetranuclear Copper Complexes Afford
   a Family of Hendecanuclear Heterometallic Complexes
   {[}Ln(3)(III)Cu(8)(II)] (Ln = La-Lu): Synthesis and Magnetostructural
   Studies}},
Journal = {{INORGANIC CHEMISTRY}},
Year = {{2013}},
Volume = {{52}},
Number = {{15}},
Pages = {{8723-8731}},
Month = {{AUG 5}},
Abstract = {{Reaction in ethanol of 3-hydroxymethylen-5-methylsalicylaldoxime (H3L)
   with CuCl2 center dot 2H(2)O and LnCl(3)center dot xH(2)O {[}Ln = La
   (1), Ce (2), Pr (3), Nd (4), Eu (5), Gd (6), Tb (7), Dy (8), Er (9), Ybo
   (10), Lu (11), Ho (12)) allowed the synthesis of a family of
   hendecanudear heterometallic copper(II)lanthanide(III) clusters with
   general formula
   {[}Ln(3)(III)Cu(8)(II)(HL)(6)(mu(4)-O)(2)Cl-6(H2O)(8))Cl-3 (1-12).
   According to the single-crystal X-ray diffraction investigation, the
   complexes are isomorphous and crystallize in the trigonal R32 group. The
   hendecanuclear cluster is formed by two tetrahedral mu(4)-oxo \{Cu-4\}
   clusters assembled by three lanthanide ions sandwiched in between. Along
   the family, the separation between the \{Cu4\} moieties increases
   linearly from Lu to La in good correlation with ionic radius of the
   lanthanide ions. A comparative analysis of the magnetic data for the
   lanthanum (1) and lutetium (11) compounds shows the presence of
   ferromagnetic and antiferromagnetic interactions within the mu(4)-oxo
   \{Cu-4\} moieties. For the gadolinium (6) and terbium (7) compounds, the
   magnetic interactions between the lanthanide and the copper ions are
   found to be ferromagnetic. The dysprosium (8) compound exhibits
   single-molecule magnet behavior.}},
