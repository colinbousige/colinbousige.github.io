Year = {{2016}},
Volume = {{4}},
Number = {{3}},
Pages = {{969-975}},
Abstract = {{Electrospinning and atomic layer deposition (ALD) have been coupled to
   prepare functional heterostructures with potential application in fuel
   cells. Electrocatalysts comprising platinum (Pt) nanoparticles dispersed
   onto electrospun carbon fibers were selectively decorated with tin
   dioxide (SnO2) using ALD. The presence of SnO2 led to a considerable
   enhancement of the catalyst durability during voltage cycling.}},
