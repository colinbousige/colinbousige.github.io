@article{ ISI:000356572100005,
Author = {Djemel, Tarek and Messai, Amel and Luneau, Dominique and Jeanneau,
   Earwann},
Title = {{Synthesis, Crystal Structures, Hydrogen Bonds and Antibacterial Activity
   of New Quinoline Derivatives}},
Journal = {{JOURNAL OF CHEMICAL CRYSTALLOGRAPHY}},
Year = {{2015}},
Volume = {{45}},
Number = {{6}},
Pages = {{300-309}},
Month = {{JUN}},
Abstract = {{Two new quinolines derivatives where crystallized from the acetylation
   reaction in low temperature ; between Baylis-Hillman products which had
   themselves been prepared from the Meth Cohn method and catalyzed by
   1,4-diazabicyclo (Fatiha et al. in J Chem Crystallogr 42:989-996, 2012)
   octane and silicon dioxide or in pyridine and chloroform. Chemical
   structures have been established by spectral techniques of FTIR, 1H NMR
   and X-ray single crystal in low temperature. The crystal structure of
   (1a) crystallizes in triclinic space group P-1, a = 7.9145(12) angstrom,
   b = 9.1412(11) angstrom, c = 10.7286(16) angstrom, alpha =
   94.760(11)degrees, beta = 105.988(13)degrees , gamma =
   101.818(11)degrees, while (2a) crystallizes in orthorhombic non-
   centrosymmetric space group Pna21, a = 7.7237(12) angstrom, b =
   20.2539(28) angstrom, c = 8.7164(12) angstrom, and its cohesion was
   found to be assured by O-H center dot center dot center dot O and C-H
   center dot center dot center dot O hydrogen bonds. Antimicrobial
   activity (in vitro) was evaluated by Gram-positive and Gram-negative
   bacteria. The compounds have shown good biological activity with
   Gram-positive bacteria (Staphylococcus aurous and Staphylococcus
   coagulase-negative).
   Graphical Abstract Two new Quinoline derivatives have been prepared with
   good products yields; these products constitute original compounds, of
   great interest biological activity.}},
