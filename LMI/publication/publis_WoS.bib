   Beshkova, M. and Vasiliauskas, R. and Syvajarvi, M. and Yakimova, R. and
   Kato, M. and Jarasionas, K.},
Editor = {{Alquier, D}},
Title = {{On applicability of time-resolved optical techniques for
   characterization of differently grown 3C-SiC crystals and
   heterostructures}},
Booktitle = {{HETEROSIC \& WASMPE 2011}},
Series = {{Materials Science Forum}},
Year = {{2012}},
Volume = {{711}},
Pages = {{159+}},
