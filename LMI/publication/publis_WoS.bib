@inproceedings{ ISI:000309431000040,
Author = {Carole, D. and Berckmans, S. and Vo-Ha, A. and Lazar, M. and Tournier,
   D. and Brosselard, P. and Souliere, V. and Auvray, L. and Ferro, G. and
   Brylinski, C.},
