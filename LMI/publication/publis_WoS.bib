@article{ ISI:000290942100008,
Author = {Borta, Ana and Gillon, Beatrice and Gukasov, Arsen and Cousson, Alain
   and Luneau, Dominique and Jeanneau, Erwann and Ciumacov, Iurii and
   Sakiyama, Hiroshi and Tone, Katsuya and Mikuriya, Masahiro},
Title = {{Local magnetic moments in a dinuclear Co2+ complex as seen by polarized
   neutron diffraction: Beyond the effective spin-1/2 model}},
Journal = {{PHYSICAL REVIEW B}},
Year = {{2011}},
Volume = {{83}},
Number = {{18}},
Month = {{MAY 25}},
Abstract = {{Polarized neutron diffraction investigations of a paramagnetic molecular
   dinuclear Co2+ complex, using the local site susceptibility method, show
   that the Co2+ ions carry opposite magnetic moments of 3.1(1) and 3.2(1)
   mu(B), making an angle of 37(1)degrees which is in agreement with the
   value (39 degrees) provided by the theoretical analysis of the magnetic
   susceptibility using the model of effective spin 1/2. Polarized neutron
   diffraction (PND) shows that this dinuclear Co2+ complex behaves more
   like a system of two antiferromagnetically coupled ions with spin 3/2,
   the directions of which are imposed by the distortion axis of the
   octahedra around each Co2+ ion due to ligand field. This first
   application of the local susceptibility tensor method to a molecular
   compound demonstrates the efficiency of the PND method as a tool for
   exploring magnetic anisotropy in molecular paramagnets.}},
